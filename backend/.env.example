# ── Supabase ──────────────────────────────────────────────────────────────────
# All found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Found in: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Database ──────────────────────────────────────────────────────────────────
# Use Transaction Pooler URL from: Supabase Dashboard → Settings → Database → Connection string
# Format: postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
POSTGRES_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── MongoDB (FHIR unstructured resources) ─────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
MONGO_DB=tenalink_fhir

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI ────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Fayda ID ──────────────────────────────────────────────────────────────────
FAYDA_API_URL=https://api.fayda.et/v1
FAYDA_API_KEY=

# ── Notifications ─────────────────────────────────────────────────────────────
AFRICASTALKING_KEY=
AFRICASTALKING_USERNAME=sandbox

# ── App ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]
DEBUG=true
